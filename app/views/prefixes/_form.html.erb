<%= form_with(model: prefix, class: "form-card") do |form| %>
  <% if prefix.errors.any? %>
    <div style="color: red; margin-bottom: 12px;">
      <h2><%= pluralize(prefix.errors.count, "error") %> prohibited this Prefix from being saved:</h2>
      <ul>
        <% prefix.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, "Prefix Name" %>
    <%= form.text_field :name, placeholder: "e.g. CS" %>
  </div>

  <div class="form-actions">
    <%= form.submit "Save Prefix", class: "button primary" %>
    <%= link_to "Cancel", prefixes_path, class: "button secondary" %>
  </div>
<% end %>
