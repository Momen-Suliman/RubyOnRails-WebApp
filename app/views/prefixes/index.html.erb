<% content_for :title, "Prefixes" %>

<div class="resource-page">
  <p class="notice"><%= notice %></p>

  <div class="page-header">
    <div>
      <h1>Prefixes</h1>
      <p>Keep course subject prefixes organized.</p>
    </div>
    <%= link_to "New prefix", new_prefix_path, class: "button primary" %>
  </div>

  <% if @prefixes.any? %>
    <div class="resource-list" id="prefixes">
      <% @prefixes.each do |prefix| %>
        <div class="resource-card">
          <h3><%= prefix.name %></h3>
          <p><%= pluralize(prefix.courses.count, "course") %> linked to this prefix.</p>
          <div class="resource-actions">
            <%= link_to "Show this prefix", prefix_path(prefix), class: "button" %>
            <%= link_to "Edit this prefix", edit_prefix_path(prefix), class: "button secondary" %>
            <%= button_to "Destroy this prefix", prefix_path(prefix), method: :delete, form: { onclick: "return confirm('⚠️ WARNING: Deleting this will cause other data dependent on it to be deleted as well!" }, class: "button danger" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      No prefixes have been added yet.
    </div>
  <% end %>
</div>
