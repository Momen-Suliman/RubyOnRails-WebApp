<% content_for :title, "Prefix details" %>

<div class="resource-page">
  <p class="notice"><%= notice %></p>

  <div class="page-header">
    <div>
      <h1><%= @prefix.name %></h1>
      <p>View the courses tied to this prefix.</p>
    </div>
    <div class="resource-actions">
      <%= link_to "Back", prefixes_path, class: "button secondary" %>
      <%= link_to "Edit", edit_prefix_path(@prefix), class: "button" %>
      <%= button_to "Delete", @prefix, method: :delete, data: { turbo_confirm: "Delete this prefix?" }, class: "button danger" %>
    </div>
  </div>

  <div class="form-card">
    <h3>Courses</h3>
    <% if @prefix.courses.any? %>
      <ul>
        <% @prefix.courses.each do |course| %>
          <li><%= link_to "#{@prefix.name} #{course.number}", course_path(course) %></li>
        <% end %>
      </ul>
    <% else %>
      <p>No courses for this prefix yet.</p>
    <% end %>
  </div>
</div>
