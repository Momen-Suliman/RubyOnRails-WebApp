<% content_for :title, "Courses" %>

<div class="resource-page">
  <p class="notice"><%= notice %></p>

  <div class="page-header">
    <div>
      <h1>Courses</h1>
      <p>Browse and manage your course catalog.</p>
    </div>
    <%= link_to "New Course", new_course_path, class: "button primary" %>
  </div>

  <% if @courses.any? %>
    <div class="resource-list" id="courses">
      <% @courses.each do |course| %>
        <div class="resource-card">
          <h3><%= "#{course.prefix.name} #{course.number}" %></h3>
          <p><%= truncate(course.syllabus.to_s, length: 140) %></p>
          <div class="resource-actions">
            <%= link_to "View", course_path(course), class: "button" %>
            <%= link_to "Edit", edit_course_path(course), class: "button secondary" %>
            <%= button_to "Delete", course_path(course), method: :delete, data: { turbo_confirm: "Delete this course?" }, class: "button danger" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      No courses available yet. Create the first one to get started.
    </div>
  <% end %>
</div>
