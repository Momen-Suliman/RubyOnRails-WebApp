<%= form_with(model: course, class: "form-card") do |form| %>
  <% if course.errors.any? %>
    <div style="color: red; margin-bottom: 12px;">
      <h2><%= pluralize(course.errors.count, "error") %> prohibited this course from being saved:</h2>
      <ul>
        <% course.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :prefix_id, "Prefix" %>
    <%= form.text_field :prefix_id, placeholder: "Enter prefix ID" %>
  </div>

  <div class="field">
    <%= form.label :number, "Number" %>
    <%= form.number_field :number %>
  </div>

  <div class="field">
    <%= form.label :syllabus, "Syllabus" %>
    <%= form.textarea :syllabus, placeholder: "Add a brief course overview" %>
  </div>

  <div class="form-actions">
    <%= form.submit class: "button primary" %>
    <%= link_to "Cancel", courses_path, class: "button secondary" %>
  </div>
<% end %>
