<% content_for :title, "Student details" %>

<div class="resource-page">
  <p class="notice"><%= notice %></p>

  <div class="page-header">
    <div>
      <h1><%= @student.name %></h1>
      <p>Student ID: <%= @student.student_id %></p>
    </div>
    <div class="resource-actions">
      <%= link_to "Back", students_path, class: "button secondary" %>
      <%= link_to "Edit", edit_student_path(@student), class: "button" %>
      <%= button_to "Delete", @student, method: :delete, data: { turbo_confirm: "Delete this student?" }, class: "button danger" %>
    </div>
  </div>

  <div class="form-card">
    <h3>Enrolled Sections</h3>
    <% if @student.sections.any? %>
      <ul>
        <% @student.sections.each do |section| %>
          <li>
            <%= link_to "#{section.course.prefix.name} #{section.course.number} • Section #{section.section_number}", section_path(section) %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>This student is not enrolled in any sections yet.</p>
    <% end %>
  </div>
</div>
