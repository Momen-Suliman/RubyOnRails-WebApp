<%= form_with(model: student, class: "form-card") do |form| %>
  <% if student.errors.any? %>
    <div style="color: red; margin-bottom: 12px;">
      <h2><%= pluralize(student.errors.count, "error") %> prohibited this student from being saved:</h2>
      <ul>
        <% student.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name, "Name" %>
    <%= form.text_field :name, placeholder: "Enter student name" %>
  </div>

  <div class="field">
    <%= form.label :student_id, "Student" %>
    <%= form.number_field :student_id, placeholder: "e.g. 1001" %>
  </div>

  <div class="field">
    <%= form.label :section_ids, "Sections" %>
    <div class="checkbox-group">
      <% @sections.each do |section| %>
        <div class="checkbox-item">
          <%= form.label "section_ids_#{section.id}", "#{section.course.prefix.name} #{section.course.number} - Section #{section.section_number}" %>
          <%= form.check_box :section_ids, { multiple: true }, section.id, nil %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "button primary" %>
    <%= link_to "Cancel", students_path, class: "button secondary" %>
  </div>
<% end %>
