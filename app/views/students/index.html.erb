<% content_for :title, "Students" %>

<div class="resource-page">
  <p class="notice"><%= notice %></p>

  <div class="page-header">
    <div>
      <h1>Students</h1>
      <p>Manage student profiles and their section enrollments.</p>
    </div>
    <%= link_to "New Student", new_student_path, class: "button primary" %>
  </div>

  <% if @students.any? %>
    <div class="resource-list" id="students">
      <% @students.each do |student| %>
        <div class="resource-card">
          <h3><%= student.name %></h3>
          <p>Student ID: <%= student.student_id %></p>
          <p><%= pluralize(student.sections.count, "section") %> enrolled.</p>
          <div class="resource-actions">
            <%= link_to "View", student_path(student), class: "button" %>
            <%= link_to "Edit", edit_student_path(student), class: "button secondary" %>
            <%= button_to "Delete", student_path(student), method: :delete, data: { turbo_confirm: "Delete this student?" }, class: "button danger" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      No students have been added yet.
    </div>
  <% end %>
</div>
