<% content_for :title, "Sections" %>

<div class="resource-page">
  <p class="notice"><%= notice %></p>

  <div class="page-header">
    <div>
      <h1>Sections</h1>
      <p>Review sections and the students assigned to each one.</p>
    </div>
    <%= link_to "New Section", new_section_path, class: "button primary" %>
  </div>

  <% if @sections.any? %>
    <div class="resource-list" id="sections">
      <% @sections.each do |section| %>
        <div class="resource-card">
          <h3><%= "#{section.course.prefix.name} #{section.course.number} • Section #{section.section_number}" %></h3>
          <p><%= pluralize(section.students.count, "student") %> enrolled.</p>
          <div class="resource-actions">
            <%= link_to "View", section_path(section), class: "button" %>
            <%= link_to "Edit", edit_section_path(section), class: "button secondary" %>
            <%= button_to "Delete", section_path(section), method: :delete, data: { turbo_confirm: "Delete this section?" }, class: "button danger" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      No sections have been created yet.
    </div>
  <% end %>
</div>
