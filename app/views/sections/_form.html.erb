<%= form_with(model: section, class: "form-card") do |form| %>
  <% if section.errors.any? %>
    <div style="color: red; margin-bottom: 12px;">
      <h2><%= pluralize(section.errors.count, "error") %> prohibited this section from being saved:</h2>
      <ul>
        <% section.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :course_id, "Course" %>
    <%= form.text_field :course_id, placeholder: "Enter course ID" %>
  </div>

  <div class="field">
    <%= form.label :section_number, "Section Number" %>
    <%= form.text_field :section_number, placeholder: "e.g. 001" %>
  </div>

  <div class="field">
    <%= form.label :student_ids, "Students" %>
    <div class="checkbox-group">
      <% @students.each do |student| %>
        <div class="checkbox-item">
          <%= form.check_box :student_ids, { multiple: true }, student.id, nil %>
          <%= form.label "student_ids_#{student.id}", "#{student.name} (ID: #{student.student_id})" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "button primary" %>
    <%= link_to "Cancel", sections_path, class: "button secondary" %>
  </div>
<% end %>
