<%= form_with(model: section) do |form| %>
  <% if section.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(section.errors.count, "error") %> prohibited this section from being saved:</h2>

      <ul>
        <% section.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :course_id, style: "display: block" %>
    <%= form.collection_select :course_id, @courses, :id, lambda { |course| "#{course.prefix.name} #{course.number}" }, { prompt: "Select a course" } %>
  </div>

  <div>
    <%= form.label :section_number, style: "display: block" %>
    <%= form.text_field :section_number %>
  </div>

  <div>
    <%= form.label "Students", style: "display: block" %>
    <div>
      <% @students.each do |student| %>
        <div>
          <%= form.check_box :student_ids, { multiple: true }, student.id, nil %>
          <%= form.label "student_ids_#{student.id}", "#{student.name} (ID: #{student.student_id})" %>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
